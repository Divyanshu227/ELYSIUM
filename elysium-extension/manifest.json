{
  "manifest_version": 3,

  "name": "ELYSIUM",

  "version": "1.1",

  "description": "GFG submission tracker",

  "permissions": [
    "activeTab"
  ],

  "host_permissions": [
    "https://*.geeksforgeeks.org/*",
    "http://localhost:3000/*"
  ],

  "content_scripts": [
    {
      "matches": [
        "https://*.geeksforgeeks.org/*"
      ],
      "js": ["content.js"]
    }
  ]
}
